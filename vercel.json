{
  "headers": [
    {
      "source": "/(.*).pdf",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/gitbook",
      "destination": "https://proxy.gitbook.site/sites/site_myC6S"
    },
    {
      "source": "/gitbook/:path*",
      "destination": "https://proxy.gitbook.site/sites/site_myC6S/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
